layout {
    gaps 10 // Gap between windows
    center-focused-column "never" // Don’t auto-center focused column

    // Setting new window opening width
    default-column-width { proportion 0.7; }

    preset-column-widths {
        proportion 0.5
        proportion 0.7
        proportion 0.9
    }

    struts {}

    focus-ring {
        width 2
        active-color "#cba6f7"
    }
}

