animations {
    workspace-switch {
        spring damping-ratio=0.8 stiffness=400 epsilon=0.0001
    }
    window-open {
        spring damping-ratio=0.8 stiffness=500 epsilon=0.0001
    }
    window-close {
        duration-ms 300
        curve "ease-out-expo"
    }
    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=400 epsilon=0.0001
    }
    window-movement {
        spring damping-ratio=1.0 stiffness=600 epsilon=0.0001
    }
    window-resize {
        spring damping-ratio=1.0 stiffness=600 epsilon=0.0001
    }
    config-notification-open-close {
        spring damping-ratio=0.7 stiffness=800 epsilon=0.001
    }
    screenshot-ui-open {
        duration-ms 400
        curve "ease-out-expo"
    }
    overview-open-close {
        spring damping-ratio=1.0 stiffness=600 epsilon=0.0001
    }
}

